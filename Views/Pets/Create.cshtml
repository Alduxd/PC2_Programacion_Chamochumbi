@model PetAdoptionApp.Models.Pet

@{
    ViewData["Title"] = "Registrar Nueva Mascota";
}

<h1>@ViewData["Title"]</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Nombre de la mascota</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Age" class="control-label">Edad</label>
                <input asp-for="Age" class="form-control" type="number" min="0" max="30" required />
                <span asp-validation-for="Age" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Type" class="control-label">Tipo</label>
                <select asp-for="Type" class="form-control" required>
                    <option value="">Seleccione un tipo</option>
                    <option value="Perro">Perro</option>
                    <option value="Gato">Gato</option>
                    <option value="Ave">Ave</option>
                    <option value="Roedor">Roedor</option>
                    <option value="Otro">Otro</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <div class="form-check">
                    <input asp-for="IsAdopted" class="form-check-input" />
                    <label asp-for="IsAdopted" class="form-check-label">¿Ya está adoptada?</label>
                </div>
            </div>
            
            <div class="form-group">
                <button type="submit" class="btn btn-primary">Registrar Mascota</button>
                <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
