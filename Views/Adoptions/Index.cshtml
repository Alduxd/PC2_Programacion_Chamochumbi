@model IEnumerable<PetAdoptionApp.Models.Adoption>

@{
    ViewData["Title"] = "Lista de Adopciones";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Registrar Nueva Adopción</a>
</p>

@if (Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Mascota</th>
                <th>Adoptante</th>
                <th>Fecha de Adopción</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Pet.Name</td>
                    <td>@item.Adopter.FullName</td>
                    <td>@item.AdoptionDate.ToShortDateString()</td>
                    <td>
                        <span class="badge bg-success">Completada</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalles</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No hay adopciones registradas. ¡Registra la primera!
    </div>
}
